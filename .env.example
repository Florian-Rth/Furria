# Copy to .env next to docker-compose.yml and fill in. Consumed by docker-compose.example.yml.

# Docker Hub namespace the CD pipeline pushes images to (your username or org).
DOCKERHUB_USERNAME=your-dockerhub-username

# PostgreSQL credentials - shared by the database and the API connection string.
POSTGRES_USER=furria
POSTGRES_PASSWORD=change-me
POSTGRES_DB=furria

# Preview-access gate password (empty denies all preview access).
PREVIEW_ACCESS_PASSWORD=

# Website API origin. Leave empty for same-origin (nginx proxies /api to the api service).
# Set to an absolute URL only if the browser must reach the API on a different host.
WEBSITE_API_BASE_URL=

# Host port the website is published on.
WEBSITE_PORT=80
