# The test-infra analyzers are fatal across the whole test tree.
#
# The analyzers ship as Warning. With <TreatWarningsAsErrors>true</TreatWarningsAsErrors> in the
# root Directory.Build.props they are already fatal everywhere; the explicit entries below pin
# MET001-005 to error regardless of warning settings. The only
# sanctioned escape hatch is an inline [SuppressMessage] where the DbContext access is the
# subject under test, not incidental.
[*.cs]
dotnet_diagnostic.MET001.severity = error
dotnet_diagnostic.MET002.severity = error
dotnet_diagnostic.MET003.severity = error
dotnet_diagnostic.MET004.severity = error
dotnet_diagnostic.MET005.severity = error
# MET006 targets production code and is skipped in test projects via build_property.IsTestProject;
# it is set to error in the root .editorconfig.
